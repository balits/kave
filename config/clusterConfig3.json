{
    "logger": {
        "kind": "text",
        "level": "debug"
    },
    "checkpoint_interval_minutes": 5,
    "peer_discovery": {
        "mode": "static",
        "peers": "node-voter-0:7000:8000,node-voter-1:7000:8000,node-voter-2:7000:8000"
    },
    "kv": {
        "max_key_size": 512,
        "max_value_size": 1024
    },
    "storage": {
        "kind": "boltdb",
        "data_dir": "data"
    },
    "compaction": {
        "threshold": 5,
        "interval_minutes": 2,
        "max_rev_gap": 10
    },
    "ot": {
        "slot_count": 32,
        "slot_size": 64,
        "token_ttl_sec": 30
    }
}