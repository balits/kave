func (e *Engine) Compact(C uint64, batchSize int) {
	cursor := e.meta.CompactionCursor()

	it := e.storage.Iterator("key_versions", cursor)

	processed := 0

	for it.Next() {
		key, rev := decode(it.Key())

		if rev >= C {
			break
		}

		// apply single-pass key logic
		// delete as needed

		processed++

		if processed >= batchSize {
			e.meta.SetCompactionCursor(it.Key())
			return
		}
	}

	e.meta.SetCompactionCursor(nil)
	e.meta.SetCompactedRevision(C)
}